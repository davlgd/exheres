require github [ user=DataDog force_git_clone=true ]

SUMMARY="A software that collects events and metrics from hosts and sends them to Datadog"

LICENCES="Apache-2.0"
SLOT="0"
PLATFORMS="~amd64 ~armv8"
MYOPTIONS=""

DEPENDENCIES="
    build:
        dev-lang/go[>=1.22.0]
        dev-lang/python[>=3.11.0]
        dev-python/docutils[>=0.18.1|<0.22][python_abis:*(-)?]
        dev-python/packaging[>=23.2][python_abis:*(-)?]
        sys-devel/cmake[>=3.12.0]
"

src_prepare() {
    esandbox disable_net
    edo pip install -r requirements.txt
    invoke install-tools
    edo go mod download
    esandbox enable_net
}

src_compile() {
    invoke agent.build --build-exclude=systemd
}

src_install() {
    mv bin/agent/agent bin/agent/${PN}
    dobin bin/agent/${PN}

    dolib.so dev/lib64/*

    insinto /usr/$(exhost --target)/include/
    doins -r dev/include/*

    emagicdocs
}

