require go [ go_minimum_version=1.21 ] github [ user="benbjohnson" tag=v${PV} ]

SUMMARY="Streaming replication for SQLite"

LICENCES="Apache-2.0"
SLOT="0"
PLATFORMS="~amd64 ~armv7 ~armv8"
MYOPTIONS=""

DEPENDENCIES=""

src_compile() {
    edo go build -C cmd/${PN} -o ${PN}
}

src_install() {
    emagicdocs
    dobin cmd/${PN}/${PN}
}

